{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wise.local/claude-split-output.schema.json",
  "title": "Claude Split Output Schema",
  "type": "object",
  "required": ["version", "tasks"],
  "properties": {
    "version": { "type": "integer", "minimum": 1 },
    "tasks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "title", "description", "role", "sourceRequirementIds", "taskAnchors"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "ordinal": { "type": "integer", "minimum": 1 },
          "title": { "type": "string", "minLength": 1 },
          "description": { "type": "string", "minLength": 1 },
          "role": { "type": "string", "enum": ["frontend", "backend", "document"] },
          "executionStatus": { "type": "string", "enum": ["executable", "not_executable"] },
          "missingPrerequisites": { "type": "array", "items": { "type": "string", "minLength": 1 } },
          "sourceRequirementIds": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "dependencies": { "type": "array", "items": { "type": "string", "minLength": 1 } },
          "subtasks": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "dod": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "taskAnchors": {
            "type": "object",
            "required": ["from", "to", "textHash", "contextBefore", "contextAfter"],
            "properties": {
              "from": { "type": "integer", "minimum": 0 },
              "to": { "type": "integer", "minimum": 1 },
              "textHash": { "type": "string", "minLength": 1 },
              "contextBefore": { "type": "string" },
              "contextAfter": { "type": "string" }
            },
            "additionalProperties": false
          }
        },
        "allOf": [
          {
            "if": { "properties": { "executionStatus": { "const": "executable" } }, "required": ["executionStatus"] },
            "then": {
              "properties": {
                "missingPrerequisites": { "type": "array", "maxItems": 0 }
              }
            }
          },
          {
            "if": { "properties": { "executionStatus": { "const": "not_executable" } }, "required": ["executionStatus"] },
            "then": {
              "properties": {
                "missingPrerequisites": { "type": "array", "minItems": 1 }
              },
              "required": ["missingPrerequisites"]
            }
          }
        ],
        "additionalProperties": true
      }
    },
    "criticalPath": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "parallelGroups": {
      "type": "array",
      "items": { "type": "array", "items": { "type": "string", "minLength": 1 } }
    },
    "unmetPreconditions": { "type": "array", "items": { "type": "string", "minLength": 1 } }
  },
  "additionalProperties": true
}

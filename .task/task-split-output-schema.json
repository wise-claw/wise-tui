{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wise.local/task-split-output-schema.json",
  "title": "Task Split Output Schema",
  "type": "object",
  "required": [
    "repo_type",
    "context_summary",
    "tasks",
    "execution_order",
    "global_missing_prerequisites",
    "assumptions"
  ],
  "properties": {
    "repo_type": {
      "type": "string",
      "enum": ["frontend", "backend", "document"]
    },
    "context_summary": {
      "type": "object",
      "required": [
        "tech_stack",
        "key_dirs",
        "constraints",
        "existing_capabilities",
        "unknowns"
      ],
      "properties": {
        "tech_stack": { "type": "array", "items": { "type": "string" } },
        "key_dirs": { "type": "array", "items": { "type": "string" } },
        "constraints": { "type": "array", "items": { "type": "string" } },
        "existing_capabilities": { "type": "array", "items": { "type": "string" } },
        "unknowns": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": false
    },
    "tasks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "title",
          "type",
          "scope",
          "depends_on",
          "description",
          "deliverables",
          "acceptance_criteria",
          "test_plan",
          "status",
          "missing_prerequisites",
          "risk_notes",
          "taskAnchors"
        ],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "title": { "type": "string", "minLength": 1 },
          "type": {
            "type": "string",
            "enum": ["feature", "refactor", "fix", "chore"]
          },
          "scope": { "type": "string", "minLength": 1 },
          "depends_on": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "description": { "type": "string", "minLength": 1 },
          "deliverables": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "acceptance_criteria": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "test_plan": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "status": {
            "type": "string",
            "enum": ["executable", "not_executable"]
          },
          "missing_prerequisites": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "risk_notes": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "taskAnchors": {
            "type": "object",
            "required": ["from", "to", "textHash", "contextBefore", "contextAfter"],
            "properties": {
              "from": { "type": "integer", "minimum": 0 },
              "to": { "type": "integer", "minimum": 1 },
              "textHash": { "type": "string", "minLength": 1 },
              "contextBefore": { "type": "string" },
              "contextAfter": { "type": "string" }
            },
            "additionalProperties": false
          }
        },
        "allOf": [
          {
            "if": {
              "properties": {
                "status": { "const": "executable" }
              }
            },
            "then": {
              "properties": {
                "missing_prerequisites": {
                  "maxItems": 0
                }
              }
            }
          },
          {
            "if": {
              "properties": {
                "status": { "const": "not_executable" }
              }
            },
            "then": {
              "properties": {
                "missing_prerequisites": {
                  "minItems": 1
                }
              }
            }
          }
        ],
        "additionalProperties": false
      }
    },
    "execution_order": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "global_missing_prerequisites": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "assumptions": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    }
  },
  "additionalProperties": false
}

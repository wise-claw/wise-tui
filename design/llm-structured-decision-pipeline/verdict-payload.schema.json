{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wise.local/schemas/workflow/verdict-payload.schema.json",
  "title": "Workflow Acceptance Verdict Payload",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schemaVersion",
    "workflowAcceptanceVerdict",
    "taskId",
    "nodeId"
  ],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "minimum": 1
    },
    "workflowAcceptanceVerdict": {
      "type": "string",
      "enum": [
        "approve",
        "reject"
      ]
    },
    "taskId": {
      "type": "string",
      "minLength": 1
    },
    "nodeId": {
      "type": "string",
      "minLength": 1
    },
    "rationale": {
      "type": "string"
    }
  }
}
